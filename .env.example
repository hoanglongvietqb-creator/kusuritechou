# Local dev (Homebrew Postgres)
DATABASE_URL=postgresql://YOUR_MAC_USER@localhost:5432/kusuri_nomitechou

# Production: Neon/Supabase connection string + sslmode=require
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local
AUTH_URL=http://localhost:3000
# Production (must match your public URL exactly)
# AUTH_URL=https://kusuritechou.vercel.app

# Medication reminder cron (Vercel Cron calls /api/cron/med-reminders)
CRON_SECRET=generate-with-openssl-rand-base64-32

# Web Push (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@gmail.com

# Password reset + med reminder email (SMTP / Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="クスリ飲み手帳 <your@gmail.com>"
